{
  "rewrites": [
    { "source": "/turnaj", "destination": "/turnaj.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin-turnaj", "destination": "/admin-turnaj.html" },
    { "source": "/api/auth/discord", "destination": "/api/auth?action=discord" },
    { "source": "/api/auth/discord/callback", "destination": "/api/auth?action=callback" },
    { "source": "/api/auth/session", "destination": "/api/auth?action=session" },
    { "source": "/api/auth/logout", "destination": "/api/auth?action=logout" },
    { "source": "/api/tournament/application", "destination": "/api/auth?action=application" },
    { "source": "/api/tournament/admin/applications", "destination": "/api/auth?action=admin-applications" },
    { "source": "/api/tournament/admin/review", "destination": "/api/auth?action=review-application" },
    { "source": "/api/tournament/state", "destination": "/api/auth?action=tournament-state" },
    { "source": "/api/tournament/join", "destination": "/api/auth?action=tournament-join" },
    { "source": "/api/tournament/vote", "destination": "/api/auth?action=tournament-vote" },
    { "source": "/api/tournament/admin/state", "destination": "/api/auth?action=tournament-admin-state" },
    { "source": "/api/tournament/admin/action", "destination": "/api/auth?action=tournament-admin-action" }
  ],
  "crons": [
    {
      "path": "/api/daily-report",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/daily-report",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/photo-contest-start",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/photo-contest-finish",
      "schedule": "0 20 * * 0"
    }
  ]
}
