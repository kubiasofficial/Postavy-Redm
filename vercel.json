{
  "rewrites": [
    { "source": "/api/auth/discord", "destination": "/api/auth?action=discord" },
    { "source": "/api/auth/discord/callback", "destination": "/api/auth?action=callback" },
    { "source": "/api/auth/session", "destination": "/api/auth?action=session" },
    { "source": "/api/auth/logout", "destination": "/api/auth?action=logout" }
  ],
  "crons": [
    {
      "path": "/api/daily-report",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/daily-report",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/photo-contest-start",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/photo-contest-finish",
      "schedule": "0 20 * * 0"
    }
  ]
}
